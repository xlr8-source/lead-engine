# =============================================================================
# PayBrix Lead Engine — Environment Configuration
# Copy to .env — add .env to .gitignore, never commit real keys
# =============================================================================

# --- LLM Provider (model-agnostic, OpenAI-compatible) ----------------------
# openai | anthropic | groq | xai | openrouter | ollama | custom | nvidia
LLM_PROVIDER=nvidia

# Generic key — checked first. Falls back to provider-specific key below.
LLM_API_KEY=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=

LLM_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# Leave blank to auto-resolve from LLM_PROVIDER.
# Required for LLM_PROVIDER=ollama or custom.
LLM_BASE_URL=

# Ordered "provider:model" fallback chain, tried on failure/rate-limit.
# e.g. groq:llama-3.3-70b-versatile,openai:gpt-4o-mini
LLM_FALLBACK_CHAIN=groq:llama-3.3-70b-versatile

LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_SECONDS=2

# --- Database ----------------------------------------------------------------
DB_PATH=leads_vault.db

# --- Governor (guard pipeline enforcement) ------------------------------------
# off   = guards do not run; assessments are stored with no quality verdict
# warn  = guards run and the verdict is recorded, but storage always proceeds
# block = a hard guard failure prevents the assessment from being stored
GUARD_ENFORCEMENT=warn

# --- API (FastAPI) -----------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000
API_ENV=development
LOG_LEVEL=INFO
# Comma-separated allow-list for cross-origin browser requests. Leave BLANK
# for a localhost install — the dashboard is served by this same app, and
# same-origin requests never consult CORS. A literal "*" is ignored.
CORS_ORIGINS=

# Optional shared key for mutating endpoints (POST /api/ingest, /api/enrich*,
# /api/email, /api/disenrich-all, /api/companies/*/contacts/refresh).
# Leave BLANK and they stay open, which is fine on 127.0.0.1. Set it before
# exposing this app to any network — callers then send X-API-Key: <value>.
# Read endpoints are never gated, so the dashboard keeps working either way.
API_KEY=

# --- Tavily Search API (web research) -----------------------------------------
TAVILY_API_KEY=
