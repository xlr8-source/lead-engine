# =============================================================================
# PayBrix Lead Engine — Environment Configuration
# Copy to .env — add .env to .gitignore, never commit real keys
# =============================================================================

# --- LLM Provider (model-agnostic, OpenAI-compatible) ----------------------
# openai | anthropic | groq | xai | openrouter | ollama | custom | nvidia
LLM_PROVIDER=nvidia

# Generic key — checked first. Falls back to provider-specific key below.
LLM_API_KEY=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=

LLM_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# Leave blank to auto-resolve from LLM_PROVIDER.
# Required for LLM_PROVIDER=ollama or custom.
LLM_BASE_URL=

# Ordered "provider:model" fallback chain, tried on failure/rate-limit.
# e.g. groq:llama-3.3-70b-versatile,openai:gpt-4o-mini
LLM_FALLBACK_CHAIN=groq:llama-3.3-70b-versatile

LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_SECONDS=2

# --- Database ----------------------------------------------------------------
DB_PATH=leads_vault.db

# --- API (FastAPI) -----------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000
API_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# --- Tavily Search API (web research) -----------------------------------------
TAVILY_API_KEY=
